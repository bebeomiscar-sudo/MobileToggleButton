local function Get_Nearest_Part(player, part_name)
    local char = player.Character
    if not char then return nil end
    if part_name == 'Head' then return char:FindFirstChild('Head')
    elseif part_name == 'HumanoidRootPart' then return char:FindFirstChild('HumanoidRootPart')
    elseif part_name == 'Torso' then return char:FindFirstChild('Torso') or char:FindFirstChild('UpperTorso')
    elseif part_name == 'Random' then
        local parts = {}
        for _, v in ipairs(char:GetChildren()) do if v:IsA('BasePart') then table.insert(parts, v) end end
        if #parts == 0 then return char:FindFirstChild('HumanoidRootPart') end
        return parts[math_random(1, #parts)]
    end
    return char:FindFirstChild(part_name)
end

local function Get_Distance(player)
    local char = player.Character
    local local_char = LocalPlayer.Character
    if not char or not local_char then return 0 end
    local root = char:FindFirstChild('HumanoidRootPart')
    local local_root = local_char:FindFirstChild('HumanoidRootPart')
    if not root or not local_root then return 0 end
    return (root.Position - local_root.Position).Magnitude
end

local function Get_Health(player)
    local char = player.Character
    if not char then return 0 end
    if States and States.GetStateValue then
        local ok, health = pcall(function() return States:GetStateValue(char, "Health", 150) end)
        if ok and health then
            local maxHealth = 150
            local ok2, mh = pcall(function() return States:GetStateValue(char, "MaxHealth", 150) end)
            if ok2 and mh then maxHealth = mh end
            return math.clamp(health / maxHealth, 0, 1)
        end
    end
    local humanoid = char:FindFirstChildOfClass('Humanoid')
    if not humanoid then return 0 end
    return humanoid.Health / humanoid.MaxHealth
end

-- ====================== FOV CIRCLE (CUSTOM SPIN) ======================
local FOV_Lines = {}
for i = 1, 64 do
    local line = Drawing.new('Line')
    line.Visible = false
    line.Thickness = 1
    FOV_Lines[i] = line
end

local function Update_FOV()
    if not FOV_Enabled then
        for _, l in ipairs(FOV_Lines) do l.Visible = false end
        return
    end

    local center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local radius = Aim_FOV
    local segments = 64

    if FOV_Spin then
        FOV_SpinAngle = (FOV_SpinAngle + FOV_SpinSpeed) % 360
    end

    local rad_offset = math_rad(FOV_SpinAngle)

    for i = 1, segments do
        local angle1 = (i - 1) * (360 / segments) + rad_offset
        local angle2 = i * (360 / segments) + rad_offset

        local x1 = center.X + math_cos(math_rad(angle1)) * radius
        local y1 = center.Y + math_sin(math_rad(angle1)) * radius
        local x2 = center.X + math_cos(math_rad(angle2)) * radius
        local y2 = center.Y + math_sin(math_rad(angle2)) * radius

        local line = FOV_Lines[i]
        line.From = v2_new(x1, y1)
        line.To = v2_new(x2, y2)
        
        -- Alternate colors for Outline1 and Outline2
        if i % 2 == 0 then
            line.Color = FOV_Outline1
            line.Transparency = FOV_OutlineTransparency
        else
            line.Color = FOV_Outline2
            line.Transparency = FOV_OutlineTransparency
        end
        
        line.Visible = true
    end
end

