-- ====================== AIMBOT LOGIC ======================
local function Get_Closest_Target()
    local closest_player = nil
    local closest_distance = Aim_FOV
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if Aim_Team_Check and player.Team == LocalPlayer.Team then continue end
        if Aim_DeathCheck and not IsAlive(player) then continue end
        resolve_player(player)
        local char = player.Character
        if not char then continue end
        local target_part = Get_Nearest_Part(player, Aim_Part)
        if not target_part then continue end
        if Aim_Visible_Check and Is_Behind_Wall(target_part) then continue end
        local screen_pos, on_screen = World_To_Screen(target_part.Position)
        if not on_screen then continue end
        local dist = (screen_pos - screen_center).Magnitude
        if dist < closest_distance then
            closest_distance = dist
            closest_player = player
        end
    end
    return closest_player
end

local function Aim_At_Target(player)
    if not player then return end
    local char = player.Character
    if not char then return end
    local target_part = Get_Nearest_Part(player, Aim_Part)
    if not target_part then return end
    if not CameraHandler or not CameraHandler.currentRotation then return end

    local targetPos = target_part.Position
    if Aim_Prediction then
        targetPos = GetPredictedPosition(target_part, Aim_ProjectileSpeed) or targetPos
    end

    local camPos = Camera.CFrame.Position
    local targetCF = CFrame.lookAt(camPos, targetPos)
    local targetPitch, targetYaw, targetRoll = targetCF:ToEulerAnglesYXZ()

    local maxPitch = CameraHandler.maxPitch or 1.5673
    targetPitch = math.clamp(targetPitch, -maxPitch, maxPitch)

    local currentRot = CameraHandler.currentRotation
    local currentPitch = currentRot.X
    local currentYaw = currentRot.Y
    local currentRoll = currentRot.Z

    local deltaYaw = targetYaw - currentYaw
    if deltaYaw > math.pi then
        deltaYaw = deltaYaw - 2 * math.pi
    elseif deltaYaw < -math.pi then
        deltaYaw = deltaYaw + 2 * math.pi
    end

    local deltaPitch = targetPitch - currentPitch
    local deltaRoll = targetRoll - currentRoll

    local targetVel = target_part.AssemblyLinearVelocity
    local isJumping = math.abs(targetVel.Y) > 5

    local alphaYaw = math.clamp(1 / Aim_SmoothX, 0.01, 1)
    local alphaPitch = math.clamp(1 / (isJumping and Aim_JumpSmooth or Aim_SmoothY), 0.01, 1)
    local alphaRoll = math.clamp(1 / Aim_SmoothZ, 0.01, 1)

    local newPitch = currentPitch + deltaPitch * alphaPitch
    local newYaw = currentYaw + deltaYaw * alphaYaw
    local newRoll = currentRoll + deltaRoll * alphaRoll

    newPitch = math.clamp(newPitch, -maxPitch, maxPitch)
    CameraHandler.currentRotation = Vector3.new(newPitch, newYaw, newRoll)
end

-- ====================== ESP UPDATE ======================
local function Update_ESP()
    Cleanup_ESP()
    local screen_size = Camera.ViewportSize

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if Aim_Team_Check and player.Team == LocalPlayer.Team then continue end
        resolve_player(player)
        local char = player.Character
        if not char then
            local d = ESP_Pool[player]
            if d then
                for _, drawing in pairs(d) do drawing.Visible = false end
            end
            continue
        end

        local hrp = char:FindFirstChild('HumanoidRootPart')
        local head = char:FindFirstChild('Head')
        if not hrp or not head then
            local d = ESP_Pool[player]
            if d then
                for _, drawing in pairs(d) do drawing.Visible = false end
            end
            continue
        end

        local root_pos, root_visible = World_To_Screen(hrp.Position)
        local head_pos, head_visible = World_To_Screen(head.Position + v3_new(0, 0.3, 0))

        local d = ESP_Pool[player]
        if not d then
            d = Create_ESP_Drawings(player)
        end

        if not root_visible and not head_visible then
            for _, drawing in pairs(d) do drawing.Visible = false end
            continue
        end

        local health = Get_Health(player)
        local distance = Get_Distance(player)
        local dist_str = tostring(math_floor(distance)) .. 'm'

        local head_size = 2
        local root_size = 2
        local head_y = head_pos.Y - head_size
        local root_y = root_pos.Y + root_size
        local height = math_abs(root_y - head_y)
        local width = height * 0.55
        local box_x = root_pos.X - width / 2
        local box_y = head_pos.Y - head_size

        if Box_Enabled and ESP_Enabled then
            d.Box_Outline.Position = v2_new(box_x, box_y)
            d.Box_Outline.Size = v2_new(width, height)
            d.Box_Outline.Visible = true
            d.Box_Outline.Color = Box_Color

            d.Box_Fill.Position = v2_new(box_x, box_y)
            d.Box_Fill.Size = v2_new(width, height)
            d.Box_Fill.Visible = true
        else
            d.Box_Outline.Visible = false
            d.Box_Fill.Visible = false
        end

        if Health_Enabled and ESP_Enabled then
            local bar_x = box_x - 6
            d.Health_Bar_BG.From = v2_new(bar_x, box_y)
            d.Health_Bar_BG.To = v2_new(bar_x, box_y + height)
            d.Health_Bar_BG.Visible = true

            local filled = height * health
            local start_y = box_y + height - filled
            d.Health_Bar.From = v2_new(bar_x, start_y)
            d.Health_Bar.To = v2_new(bar_x, box_y + height)
            d.Health_Bar.Visible = true

            local r = (1 - health) * 255
            local g = health * 255
            d.Health_Bar.Color = Color3.fromRGB(r, g, 40)
        else
            d.Health_Bar_BG.Visible = false
            d.Health_Bar.Visible = false
        end

        if Name_Enabled and ESP_Enabled then
            d.Name_Text.Text = player.DisplayName
            d.Name_Text.Position = v2_new(root_pos.X, box_y - 14)
            d.Name_Text.Visible = true
            d.Name_Text.Color = Name_Color
        else
            d.Name_Text.Visible = false
        end

        if Distance_Enabled and ESP_Enabled then
            d.Distance_Text.Text = dist_str
            d.Distance_Text.Position = v2_new(root_pos.X, box_y + height + 4)
            d.Distance_Text.Visible = true
        else
            d.Distance_Text.Visible = false
        end

        if Tracer_Enabled and ESP_Enabled then
            local origin_x = screen_size.X / 2
            local origin_y = Tracer_Origin == 'Bottom' and screen_size.Y
                or Tracer_Origin == 'Top' and 0
                or screen_size.Y / 2

            d.Tracer_Line.From = v2_new(origin_x, origin_y)
            d.Tracer_Line.To = v2_new(root_pos.X, root_pos.Y)
            d.Tracer_Line.Visible = true
            d.Tracer_Line.Color = Tracer_Color
        else
            d.Tracer_Line.Visible = false
        end

        if Head_Dot_Enabled and ESP_Enabled then
            d.Head_Dot.Position = head_pos
            d.Head_Dot.Visible = true
            d.Head_Dot.Color = Head_Dot_Color
        else
            d.Head_Dot.Visible = false
        end
    end
end

