local ShotRemote = RepStorage:WaitForChild("Remotes"):WaitForChild("shot", 10)
local ShotMultiRemote = RepStorage:WaitForChild("Remotes"):WaitForChild("shot_multi", 10)

local function DrawTracer(origin, hitPos)
    local dist = (origin - hitPos).Magnitude
    local pos1 = origin
    local pos2 = hitPos
    
    local part = Instance.new('Part')
    part.Anchored = true
    part.CanCollide = false
    part.CanQuery = false
    part.Material = Enum.Material.Neon
    part.Color = BT_Color
    part.Size = Vector3.new(0.1, 0.1, dist)
    part.CFrame = CFrame.lookAt(pos1, pos2) * CFrame.new(0, 0, -dist / 2)
    part.Parent = Workspace
    
    Debris:AddItem(part, BT_Duration)
end

local function HookBulletTracers()
    local oldFire = ShotRemote.FireServer
    ShotRemote.FireServer = function(self, ...)
        local args = {...}
        if BT_Enabled and type(args[2]) == 'table' then
            local origin = args[2].origin or args[2].from or args[2].cameraPosition
            local hitPos = args[2].hitPosition or args[2].position or args[2].hit
            if origin and hitPos then
                DrawTracer(origin, hitPos)
            end
        end
        return oldFire(self, table.unpack(args))
    end

    local oldFireMulti = ShotMultiRemote.FireServer
    ShotMultiRemote.FireServer = function(self, ...)
        local args = {...}
        if BT_Enabled and type(args[2]) == 'table' then
            local origin = args[2].origin or args[2].from or args[2].cameraPosition
            local hitPos = args[2].hitPosition or args[2].position or args[2].hit
            if origin and hitPos then
                DrawTracer(origin, hitPos)
