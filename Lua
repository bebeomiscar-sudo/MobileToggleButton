                if txt and (txt == lpName or txt == lpUserName or txt:find(lpName) or txt:find(lpUserName)) then
                    local parent = desc.Parent
                    if parent then
                        for _, sibling in ipairs(parent:GetChildren()) do
                            if sibling:IsA("TextLabel") and sibling ~= desc then
                                local t = sibling.Text:lower()
                                if t:find("lvl") or t:find("level") then
                                    sibling.Text = "Lvl. " .. tostring(LB_Level)
                                elseif t:find("streak") or t:find("ws") or t:find("win") then
                                    sibling.Text = tostring(LB_Streak) .. " WS"
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end

