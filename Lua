local function FetchWithRetry(url, attempts)
    attempts = attempts or 5
    for i = 1, attempts do
        local ok, result = pcall(game.HttpGet, game, url)
        if ok and type(result) == 'string' and #result > 0 then return result end
        task.wait(0.6 * i)
    end
    return nil
end

local function FetchFirstWorking(urls, attemptsPerUrl)
    for _, url in next, urls do
        local result = FetchWithRetry(url, attemptsPerUrl)
        if result then return result, url end
    end
    error('[Loader] All URLs failed')
end

local function LoadModule(fullUrlOrList, label)
    local urls = type(fullUrlOrList) == 'table' and fullUrlOrList or { fullUrlOrList }
    local source = FetchFirstWorking(urls, 3)
    local chunk = loadstring(source, label)
    if not chunk then error('[Loader] Failed to compile ' .. label) end
    return chunk()
end

