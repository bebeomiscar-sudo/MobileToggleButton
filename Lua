-- ====================== AIMBOT LOGIC ======================
local function IsTargetValid(player)
    if not player then return false end
    if player == LocalPlayer then return false end
    if IsSameTeam(player) then return false end
    if Aim_DeathCheck and not IsAlive(player) then return false end
    resolve_player(player)
    local char = player.Character
    if not char then return false end
    local target_part = Get_Nearest_Part(player, Aim_Part)
    if not target_part then return false end
    if Get_Distance(player) > Aim_Distance then return false end
    if Aim_Visible_Check then
        local origin = Camera.CFrame.Position
        local ray = Ray.new(origin, target_part.Position - origin)
        local hit = Workspace:FindPartOnRayWithIgnoreList(ray, { LocalPlayer.Character }, false, true)
        if hit and not hit:IsDescendantOf(char) then return false end
    end
    local screen_pos, on_screen = World_To_Screen(target_part.Position)
    if not on_screen then return false end
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local dist = (screen_pos - screen_center).Magnitude
    if dist > Aim_FOV then return false end
    return true
end

local function GetScreenDistance(player)
    local target_part = Get_Nearest_Part(player, Aim_Part)
    if not target_part then return math.huge end
    local screen_pos, on_screen = World_To_Screen(target_part.Position)
    if not on_screen then return math.huge end
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    return (screen_pos - screen_center).Magnitude
end

local function Get_Closest_Target()
    local closest_player = nil
    local closest_distance = Aim_FOV

    if Aim_CurrentTarget and Aim_CurrentTarget.Parent then
        if IsTargetValid(Aim_CurrentTarget) then
            local current_dist = GetScreenDistance(Aim_CurrentTarget)
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= Aim_CurrentTarget and IsTargetValid(player) then
                    local new_dist = GetScreenDistance(player)
                    if new_dist < current_dist * 0.6 then
                        closest_player = player
                        closest_distance = new_dist
                    end
                end
            end
            if closest_player then return closest_player end
            return Aim_CurrentTarget
        end
    end

    Aim_CurrentTarget = nil
    for _, player in ipairs(Players:GetPlayers()) do
        if IsTargetValid(player) then
            local dist = GetScreenDistance(player)
            if dist < closest_distance then
                closest_distance = dist
                closest_player = player
            end
        end
    end
    return closest_player
end

local function Aim_At_Target(player)
    if not player then return end
    local char = player.Character
    if not char then return end
    local target_part = Get_Nearest_Part(player, Aim_Part)
    if not target_part then return end
    if not CameraHandler or not CameraHandler.currentRotation then return end

    local targetPos = target_part.Position
    local camPos = Camera.CFrame.Position
    local targetCF = CFrame.lookAt(camPos, targetPos)
    local targetPitch, targetYaw, _ = targetCF:ToEulerAnglesYXZ()

    local maxPitch = CameraHandler.maxPitch or 1.5673
    targetPitch = math.clamp(targetPitch, -maxPitch, maxPitch)

    local currentRot = CameraHandler.currentRotation
    local currentPitch = currentRot.X
    local currentYaw = currentRot.Y

    local deltaYaw = targetYaw - currentYaw
    while deltaYaw > math_pi do deltaYaw = deltaYaw - 2 * math_pi end
    while deltaYaw < -math_pi do deltaYaw = deltaYaw + 2 * math_pi end

    local deltaPitch = targetPitch - currentPitch

    local base_speed = Aim_IsFiring and Aim_SpeedInAttack or Aim_Speed
    local effective_speed = base_speed * (Aim_SpeedScale / 100)
    local alpha = math.clamp(effective_speed, 0.001, 1)

    local newPitch = currentPitch + deltaPitch * alpha
    local newYaw = currentYaw + deltaYaw * alpha

    newPitch = math.clamp(newPitch, -maxPitch, maxPitch)
    CameraHandler.currentRotation = Vector3.new(newPitch, newYaw, 0)
end

