local function Update_FullAuto()
    if not FA_Enabled then return end
    if not NR_IsFiring then return end
    local now = tick()
    if now - FA_LastFire >= FA_Speed then
        pcall(function()
            if mouse1click then
                mouse1click()
            elseif vim then
                vim:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                task.wait(0.01)
                vim:SendMouseButtonEvent(0, 0, 0, false, game, 0)
            end
        end)
        FA_LastFire = now
    end
end

-- ====================== BULLET TRACER LOGIC ======================
local function Update_BulletTracers()
    local now = tick()
    for i = #BT_Pool, 1, -1 do
        local t = BT_Pool[i]
        if now > t.expire then
            pcall(function() t.drawing:Remove() end)
            table.remove(BT_Pool, i)
        else
            local remaining = (t.expire - now) / t.duration
            t.drawing.Transparency = 1 - remaining
        end
    end
end

