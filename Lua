-- ====================== SILENT AIM LOGIC ======================
local function Get_SilentAim_Target()
    local closest_player = nil
    local closest_distance = SA_FOV
    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if SA_TeamCheck and player.Team == LocalPlayer.Team then continue end
        if SA_DeathCheck and not IsAlive(player) then continue end
        resolve_player(player)
        local char = player.Character
        if not char then continue end
        local target_part = Get_Nearest_Part(player, SA_TargetPart)
        if not target_part then continue end
        if SA_VisibleCheck and Is_Behind_Wall_Enhanced(target_part) then continue end
        local screen_pos, on_screen = World_To_Screen(target_part.Position)
        if not on_screen then continue end
        local dist = (screen_pos - screen_center).Magnitude
        if dist < closest_distance then
            closest_distance = dist
            closest_player = player
        end
    end
    return closest_player
end

-- ====================== SHOT REMOTE HOOK (LAZY) ======================
local function HookShotRemote()
    if SA_Hooked then return end
    if not hookmetamethod then return end
    if not ShotRemote then return end

    local safeCC = newcclosure or function(f) return f end

    local oldNamecall = hookmetamethod(game, "__namecall", safeCC(function(...)
        local args = {...}
        local self = args[1]
        local method = getnamecallmethod()

        if not (self == ShotRemote) then
            return oldNamecall(...)
        end

        if method ~= "FireServer" and method ~= "fire" and method ~= "send" then
            return oldNamecall(...)
        end

        local originalHitPos = nil
        if type(args[2]) == "table" then
            originalHitPos = args[2].position or args[2].hitPosition or args[2].Position
        elseif typeof(args[2]) == "Vector3" then
            originalHitPos = args[2]
        elseif typeof(args[3]) == "Vector3" then
            originalHitPos = args[3]
        end

        if BT_Enabled and originalHitPos then
            local muzzlePos = Camera.CFrame.Position
            local screenFrom, visFrom = World_To_Screen(muzzlePos)
            local screenTo, visTo = World_To_Screen(originalHitPos)
            if visFrom and visTo then
                local line = Drawing.new('Line')
                line.Visible = true
                line.From = screenFrom
                line.To = screenTo
                line.Color = BT_Color
                line.Thickness = BT_Thickness
                line.Transparency = 0.2
                table.insert(BT_Pool, {drawing = line, expire = tick() + BT_Duration, duration = BT_Duration})
            end
        end

        if SA_Enabled then
            local target = Get_SilentAim_Target()
            if target then
                local targetPart = Get_Nearest_Part(target, SA_TargetPart)
                if targetPart then
                    local hitPos = targetPart.Position
                    if SA_Prediction then
                        hitPos = GetPredictedPosition(targetPart, SA_ProjectileSpeed) or hitPos
                    end

                    if type(args[2]) == "table" then
                        if args[2].position then args[2].position = hitPos end
                        if args[2].hitPosition then args[2].hitPosition = hitPos end
                        if args[2].Position then args[2].Position = hitPos end
                        if args[2].target then args[2].target = targetPart end
                        if args[2].hitPart then args[2].hitPart = targetPart end
                    elseif typeof(args[2]) == "Vector3" then
                        args[2] = hitPos
                    elseif typeof(args[3]) == "Vector3" then
                        args[3] = hitPos
                    end
                end
            end
        end

        return oldNamecall(table.unpack(args))
    end))

    SA_Hooked = true
end

-- ====================== TRIGGERBOT LOGIC (SAFER) ======================
local TB_LastFire = 0

local function Update_Triggerbot()
    if not TB_Enabled then return end
    local now = tick()
    if now - TB_LastFire < TB_Delay then return end

    local screen_center = v2_new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local closest_dist = TB_FOV

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if TB_TeamCheck and player.Team == LocalPlayer.Team then continue end
        if TB_DeathCheck and not IsAlive(player) then continue end
        resolve_player(player)
        local char = player.Character
        if not char then continue end
        local target_part = Get_Nearest_Part(player, TB_TargetPart)
        if not target_part then continue end
        if TB_VisibleCheck and Is_Behind_Wall_Enhanced(target_part) then continue end
        local screen_pos, on_screen = World_To_Screen(target_part.Position)
        if not on_screen then continue end
        local dist = (screen_pos - screen_center).Magnitude
        if dist < closest_dist then
            closest_dist = dist
            pcall(function()
                if mouse1click then
                    mouse1click()
                elseif vim then
                    vim:SendMouseButtonEvent(0, 0, 0, true, game, 0)
                    task.wait(0.01)
                    vim:SendMouseButtonEvent(0, 0, 0, false, game, 0)
                end
            end)
            TB_LastFire = now
            break
        end
    end
end

-- ====================== NO RECOIL LOGIC ======================
local function Update_NoRecoil()
    if not NR_Enabled then
        NR_LastPitch = nil
        NR_LastYaw = nil
        return
    end
    if not CameraHandler or not CameraHandler.currentRotation then return end
    local current = CameraHandler.currentRotation

    if not NR_IsFiring then
        NR_LastPitch = current.X
        NR_LastYaw = current.Y
    else
        if NR_PitchLock and NR_LastPitch then
            local recoilDelta = current.X - NR_LastPitch
            local correctedPitch = current.X - (recoilDelta * NR_Intensity)
            local maxPitch = CameraHandler.maxPitch or 1.5673
            correctedPitch = math.clamp(correctedPitch, -maxPitch, maxPitch)
            CameraHandler.currentRotation = Vector3.new(correctedPitch, current.Y, current.Z)
        end
        if NR_YawLock and NR_LastYaw then
            local recoilDeltaY = current.Y - NR_LastYaw
            local correctedYaw = current.Y - (recoilDeltaY * NR_Intensity)
            CameraHandler.currentRotation = Vector3.new(current.X, correctedYaw, current.Z)
        end
    end
end

-- ====================== HITBOX EXPANDER LOGIC ======================
local function Update_Hitbox()
    if not HB_Enabled then
        for player, parts in pairs(HB_OriginalSizes) do
            if player.Parent then
                local char = player.Character
                if char then
                    for partName, origSize in pairs(parts) do
                        local part = char:FindFirstChild(partName)
                        if part and part:IsA('BasePart') then
                            part.Size = origSize
                            part.Transparency = 0
                            part.Material = Enum.Material.Plastic
                        end
                    end
                end
            end
        end
        HB_OriginalSizes = {}
        return
    end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if HB_TeamCheck and player.Team == LocalPlayer.Team then continue end
        if HB_DeathCheck and not IsAlive(player) then continue end
        resolve_player(player)
        local char = player.Character
        if not char then continue end
        local target = Get_Nearest_Part(player, HB_Part)
        if not target then continue end

        if not HB_OriginalSizes[player] then HB_OriginalSizes[player] = {} end
        if not HB_OriginalSizes[player][target.Name] then
            HB_OriginalSizes[player][target.Name] = target.Size
        end

        target.Size = Vector3.new(HB_Size, HB_Size, HB_Size)
        target.Transparency = HB_Transparency
        target.Color = Color3.fromRGB(255, 0, 0)
        target.Material = Enum.Material.Neon
    end
end

