        local Milk = require(RS:WaitForChild("Milk"))
        Milk.Constants.UnlockAllUserIds = Milk.Constants.UnlockAllUserIds or {}
        Milk.Constants.UnlockAllUserIds[LP.UserId] = true
        Milk:Init()

        local nidToWName = {}
        for name, data in pairs(Milk.Directory.Items.all) do
            if type(data) == "table" and data.nID then
                local nid = data.nID
                nidToWName[nid] = name
                nidToWName[tostring(nid)] = name
            end
        end

        local CONFIG_PATH = "overkill_skins.json"
        local DEFAULTS = {
            ak47 = "", shotgun = "", deagle = "", handgun = "", tec9 = "", katana = "",
            scythe = "", karambit = "", shorty = "", raygun = "", medkit = "", minigun = "",
            grenade = "", rpg = "", burst = "", pulse_rifle = "", bolt_action_sniper = "", tommy_gun = "",
        }

        local function loadConfig()
            local ok, data = pcall(readfile, CONFIG_PATH)
            if ok and data and data ~= "" then
                local ok2, tbl = pcall(HttpService.JSONDecode, HttpService, data)
                if ok2 and type(tbl) == "table" then return tbl end
            end
            return {}
        end

        local function saveConfig()
            local ok, json = pcall(function() return HttpService:JSONEncode(getgenv().__Equipped) end)
            if ok then pcall(writefile, CONFIG_PATH, json) end
        end

        getgenv().__Equipped = loadConfig()
        if next(getgenv().__Equipped) == nil then
            for k, v in pairs(DEFAULTS) do getgenv().__Equipped[k] = v end
            saveConfig()
        end
        local function getSkin(w) return getgenv().__Equipped[w] or DEFAULTS[w] end

        local dh = Milk.Handlers.DataHandler
        if dh and dh.GetDataAsync then
            local orig = dh.GetDataAsync
            dh.GetDataAsync = function(self, ...)
                local data = orig(self, ...)
                if type(data) == "table" and type(data.Items) == "table" then
                    local real = data.Items
                    data.Items = setmetatable({}, {
                        __index = function(t, nid)
                            local r = real[nid]
                            if not r then return nil end
                            local wName = nidToWName[nid] or nidToWName[tostring(nid)]
                            if wName then
                                local s = getSkin(wName)
                                if s then
                                    local item = {}
                                    for k, v in next, r do item[k] = v end
                                    item.skin = s
                                    return item
                                end
                            end
                            return r
                        end,
                        __newindex = function(t, k, v) real[k] = v end,
                        __pairs = function() return pairs(real) end
                    })
                end
                return data
            end
        end

        pcall(function()
            local neuron = require(RF:WaitForChild("neuron"))
            if neuron and neuron.net and neuron.net.packets and neuron.net.packets.armory_change_skin then
                local pkt = neuron.net.packets.armory_change_skin
                local orig = pkt.Fire
                pkt.Fire = function(self, weaponName, skinName)
                    if type(weaponName) == "string" and type(skinName) == "string" then
                        getgenv().__Equipped[weaponName] = skinName
                        saveConfig()
                    end
                    return orig(self, weaponName, skinName)
                end
            end
        end)

        local chickModule = require(RF.Packages.Chickynoid.Client.ClientModule)
        RunService.Heartbeat:Connect(function()
            pcall(function()
                local chick = chickModule.localChickynoid
                if not chick or not chick.simulation then return end
                local state = chick.simulation.state
                if not state then return end
                for i = 1, 4 do
                    local wid = state["slot" .. i .. "_weaponID"]
                    if wid and wid ~= "" then
                        local s = getSkin(wid)
                        if s then state["slot" .. i .. "_skin"] = s end
                    end
                end
            end)
        end)
    end)
end

