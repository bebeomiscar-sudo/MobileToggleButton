    end
end

-- ====================== CHARMS ======================
local CH_WeaponEnabled = false
local CH_ArmEnabled = false
local CH_Selected = 'None'
local CH_Material = Enum.Material.Neon

local function Apply_Charms()
    if not CH_WeaponEnabled and not CH_ArmEnabled then return end
    pcall(function()
        local charmsFolder = RepStorage:WaitForChild('Assets'):WaitForChild('Charms')
        local charm = charmsFolder:FindFirstChild(CH_Selected)
        if not charm then return end

        local char = LocalPlayer.Character
        if not char then return end

        if CH_WeaponEnabled then
            local tool = char:FindFirstChildOfClass('Tool')
            if tool then
                local handle = tool:FindFirstChild('Handle')
                if handle and not handle:FindFirstChild('WeaponCharm') then
                    local clone = charm:Clone()
                    clone.Name = 'WeaponCharm'
                    clone.Material = CH_Material
                    clone.Parent = handle
                    clone.CFrame = handle.CFrame * CFrame.new(0, 0.5, 0)
                end
            end
        end

        if CH_ArmEnabled then
            local arm = char:FindFirstChild('RightHand') or char:FindFirstChild('Right Arm')
            if arm and not arm:FindFirstChild('ArmCharm') then
                local clone = charm:Clone()
                clone.Name = 'ArmCharm'
                clone.Material = CH_Material
                clone.Parent = arm
                clone.CFrame = arm.CFrame * CFrame.new(0, -0.5, 0)
            end
        end
    end)
end

