    for _, ent in ipairs(entities:GetChildren()) do
        if ent:GetAttribute('IsDummy') == true then
            local hrp = ent:FindFirstChild('HumanoidRootPart')
            local hum = ent:FindFirstChildOfClass('Humanoid')
            if hrp and hum and hum.Health > 0 then
                local dist = (myPos - hrp.Position).Magnitude
                if dist < closest_dist then
                    closest_dist = dist
                    closest_ent = ent
                end
            end
        end
    end
    return closest_ent
end

local function Update_Dummy_Aimbot()
    if not DA_Enabled then
        DA_CurrentTarget = nil
        return
    end

    if DA_Sticky and DA_CurrentTarget and DA_CurrentTarget.Parent then
        local hum = DA_CurrentTarget:FindFirstChildOfClass('Humanoid')
        if not hum or hum.Health <= 0 then DA_CurrentTarget = nil end
    else
        DA_CurrentTarget = Get_Dummy_Target()
    end

    if DA_CurrentTarget then
        local head = DA_CurrentTarget:FindFirstChild('Head')
        if head and CameraHandler and CameraHandler.currentRotation then
            local targetPos = head.Position
            if DA_Prediction > 0 then
                local vel = head.AssemblyLinearVelocity
                targetPos = targetPos + Vector3.new(vel.X * DA_Prediction, vel.Y * DA_Prediction, vel.Z * DA_Prediction)
            end

            local camPos = Camera.CFrame.Position
            local targetCF = CFrame.lookAt(camPos, targetPos)
            local targetPitch, targetYaw, _ = targetCF:ToEulerAnglesYXZ()
            local maxPitch = CameraHandler.maxPitch or 1.5673
            targetPitch = math.clamp(targetPitch, -maxPitch, maxPitch)

            local currentRot = CameraHandler.currentRotation
            local currentPitch = currentRot.X
            local currentYaw = currentRot.Y

            local deltaYaw = targetYaw - currentYaw
            while deltaYaw > math_pi do deltaYaw = deltaYaw - 2 * math_pi end
            while deltaYaw < -math_pi do deltaYaw = deltaYaw + 2 * math_pi end

            local deltaPitch = targetPitch - currentPitch
            local alpha = math.clamp(DA_Smoothness, 0.01, 1)

            local newPitch = currentPitch + deltaPitch * alpha
            local newYaw = currentYaw + deltaYaw * alpha

            if DA_Shake then
                newPitch = newPitch + (math_random() - 0.5) * 0.02
                newYaw = newYaw + (math_random() - 0.5) * 0.02
            end

            newPitch = math.clamp(newPitch, -maxPitch, maxPitch)
